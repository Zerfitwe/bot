from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
import time
import random
import os

# ==================== НАЛАШТУВАННЯ ====================

SEARCH_QUERY = "Децкоє питання"
COMMENTS_TOTAL = 15  # Скільки всього коментарів зробити
MAX_RETRIES = 3  # Скільки разів пробувати коментувати, якщо не вийшло

# Паузи (в секундах)
DELAY_BEFORE_COMMENT = (3, 6)      # Пауза перед коментарем
DELAY_AFTER_COMMENT = (8, 12)      # Пауза після коментаря
DELAY_BETWEEN_VIDEOS = (10, 15)    # Пауза між відео
TYPE_SPEED = (0.05, 0.15)          # Швидкість друку (сек між буквами)
WAIT_FOR_COMMENT = (3, 5)          # Час очікування появи коментаря

# Слова для коментарів
short_words = [
    "круто", "супер", "топ", "класс", "вау", "мега", "красота",
    "имба", "кайф", "шедевр", "прекрасно", "огонь", "сила", 
    "топчик", "крутяк", "зачет", "ништяк", "смешно", "прикольно",
    "реально", "точно", "🔥", "💯", "😍", "пушка", "имбово"
]

long_words = [
    "невероятно", "фантастически", "потрясающе", "захватывающе",
    "восхитительно", "бесподобно", "безупречно", "великолепно",
    "лучший", "гениально", "профессионально", "талантливо",
    "мастерски", "креативно", "оригинально", "уникально",
    "вдохновляюще", "мотивирующе", "энергично", "динамично"
]

def generate_comment():
    """Генерує випадковий коментар"""
    base = "@Lisscre "
    if random.choice([True, False]):
        num = random.randint(1, 3)
        words = random.sample(short_words, num)
    else:
        num = random.randint(2, 4)
        words = random.sample(long_words, num)
    return base + " ".join(words)

def type_like_human(element, text):
    """Друкує текст як людина (з затримками між буквами)"""
    for char in text:
        element.send_keys(char)
        time.sleep(random.uniform(TYPE_SPEED[0], TYPE_SPEED[1]))

def wait_human_like(min_sec, max_sec):
    """Людська пауза"""
    time.sleep(random.uniform(min_sec, max_sec))

def scroll_slowly(driver, pixels=300):
    """Плавно прокручує сторінку"""
    driver.execute_script(f"window.scrollBy(0, {pixels});")
    time.sleep(random.uniform(0.5, 1))

def check_comment_added(driver, comment_text):
    """Перевіряє, чи додався коментар"""
    try:
        # Шукаємо коментарі на сторінці
        comments = driver.find_elements(By.CSS_SELECTOR, "[data-e2e='comment-text']")
        for comment in comments:
            if comment_text[:20] in comment.text:
                return True
        return False
    except:
        return False

def try_to_comment(driver, comment_text, video_number):
    """Спроба закоментувати з перевіркою"""
    
    for attempt in range(MAX_RETRIES):
        print(f"    Попытка {attempt + 1}/{MAX_RETRIES}...")
        
        try:
            # Шукаємо поле коментаря
            comment_input = None
            
            # Спосіб 1: через клас public-DraftEditor-content
            try:
                comment_input = driver.find_element(By.CSS_SELECTOR, "div.public-DraftEditor-content")
            except:
                pass
            
            # Спосіб 2: через textarea
            if not comment_input:
                try:
                    comment_input = driver.find_element(By.TAG_NAME, "textarea")
                except:
                    pass
            
            # Спосіб 3: через data-e2e
            if not comment_input:
                try:
                    comment_input = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-input']")
                except:
                    pass
            
            if not comment_input:
                print(f"    ❌ Не знайдено поле коментаря")
                return False
            
            # Клікаємо на поле
            comment_input.click()
            wait_human_like(0.5, 1)
            
            # Очищаємо поле
            comment_input.clear()
            wait_human_like(0.3, 0.8)
            
            # Друкуємо коментар
            type_like_human(comment_input, comment_text)
            wait_human_like(1, 2)
            
            # Шукаємо кнопку відправки
            submit = None
            try:
                submit = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-post']")
            except:
                try:
                    submit = driver.find_element(By.XPATH, "//button[contains(text(), 'Отправить')]")
                except:
                    pass
            
            if submit:
                submit.click()
                print(f"    📤 Отправлено...")
            else:
                comment_input.send_keys(Keys.RETURN)
                print(f"    📤 Отправлено через Enter...")
            
            # Чекаємо появи коментаря
            wait_human_like(WAIT_FOR_COMMENT[0], WAIT_FOR_COMMENT[1])
            
            # ПЕРЕВІРЯЄМО, ЧИ ДОДАВСЯ КОМЕНТАР
            if check_comment_added(driver, comment_text):
                print(f"    ✅ КОМЕНТАР ДОДАНО! (спроба {attempt + 1})")
                return True
            else:
                print(f"    ⚠️ Коментар не з'явився, пробуємо ще...")
                
        except Exception as e:
            print(f"    ❌ Помилка: {str(e)[:50]}")
        
        # Пауза перед наступною спробою
        if attempt < MAX_RETRIES - 1:
            wait_human_like(2, 4)
    
    print(f"    ❌ НЕ ВДАЛОСЯ ЗАКОМЕНТУВАТИ після {MAX_RETRIES} спроб")
    return False

print("=" * 70)
print("🤖 TikTok АВТОМАТИЧНИЙ БОТ (з перевіркою коментарів)")
print("=" * 70)
print(f"\n📊 НАЛАШТУВАННЯ:")
print(f"   - Пошук: {SEARCH_QUERY}")
print(f"   - Коментарів: {COMMENTS_TOTAL}")
print(f"   - Максимум спроб: {MAX_RETRIES}")
