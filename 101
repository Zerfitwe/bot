print("=" * 70)

# ========== ЗАПУСК БРАУЗЕРА ==========
print("\n📥 Запускаємо Chrome...")

user_data_dir = os.path.join(os.getcwd(), "chrome_session")
options = webdriver.ChromeOptions()
options.add_argument(f"--user-data-dir={user_data_dir}")
options.add_argument("--disable-blink-features=AutomationControlled")
options.add_experimental_option("excludeSwitches", ["enable-automation"])

driver = webdriver.Chrome(options=options)
driver.get("https://www.tiktok.com")
time.sleep(5)

print("\n⚠️ Увійдіть в TikTok вручну і натисніть Enter...")
print("   (Це потрібно зробити один раз)")
input()

# ========== ПОШУК ВІДЕО ==========
print(f"\n🔍 Шукаємо: {SEARCH_QUERY}")

try:
    search = WebDriverWait(driver, 10).until(
        EC.presence_of_element_located((By.NAME, "q"))
    )
    search.clear()
    search.send_keys(SEARCH_QUERY)
    search.send_keys(Keys.RETURN)
    time.sleep(5)
    print("✅ Пошук виконано!")
except Exception as e:
    print(f"⚠️ Помилка пошуку: {e}")
    print("Зробіть пошук вручну і натисніть Enter...")
    input()

# ========== ЗБИРАЄМО ВІДЕО ==========
print("\n📹 Збираємо відео...")

for i in range(3):
    scroll_slowly(driver, 800)
    wait_human_like(1, 2)

videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
print(f"Знайдено відео: {len(videos)}")

if len(videos) == 0:
    print("❌ Відео не знайдено!")
    driver.quit()
    exit()

# ========== ОСНОВНИЙ ЦИКЛ КОМЕНТУВАННЯ ==========
print(f"\n🚀 Починаємо коментувати...")
print("=" * 70)

comments_done = 0
video_index = 0
skipped_videos = 0

while comments_done < COMMENTS_TOTAL:
    try:
        # Оновлюємо список відео якщо треба
        if video_index >= len(videos):
            print("\n📜 Прокручуємо сторінку для завантаження нових відео...")
            scroll_slowly(driver, 1000)
            wait_human_like(2, 3)
            videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
            print(f"Тепер знайдено: {len(videos)} відео")
            if video_index >= len(videos):
                print("⚠️ Відео закінчилися!")
                break
        
        print(f"\n{'='*60}")
        print(f"📹 ВІДЕО #{comments_done + 1} з {COMMENTS_TOTAL}")
        print(f"{'='*60}")
        
        # Отримуємо URL відео
        video_url = videos[video_index].get_attribute("href")
        print(f"  🔗 Відкриваємо відео...")
        
        # Відкриваємо відео
        driver.get(video_url)
        wait_human_like(4, 6)
        
        # Перевіряємо чи відео відкрилося
        if "video" not in driver.current_url:
            print(f"  ❌ Не вдалося відкрити відео")
            video_index += 1
            continue
        
        print(f"  ✅ Відео відкрито!")
        
        # Пауза перед коментарем
        print(f"  ⏱️ Пауза перед коментарем...")
        wait_human_like(DELAY_BEFORE_COMMENT[0], DELAY_BEFORE_COMMENT[1])
        
        # Генеруємо коментар
        comment_text = generate_comment()
        print(f"  📝 Коментар: {comment_text}")
        
        # Пробуємо закоментувати з перевіркою
        success = try_to_comment(driver, comment_text, comments_done + 1)
        
        if success:
            comments_done += 1
            
            # Пауза після успішного коментаря
            print(f"  ⏱️ Пауза після коментаря...")
            wait_human_like(DELAY_AFTER_COMMENT[0], DELAY_AFTER_COMMENT[1])
        else:
            skipped_videos += 1
            print(f"  ⚠️ Пропускаємо це відео")
            wait_human_like(3, 5)
        
        # Закриваємо відео (повертаємось до стрічки)
        print(f"  🔙 Повертаємось до стрічки...")
        driver.back()
        wait_human_like(3, 5)
        
        # Переходимо до наступного відео
        video_index += 1
        
        # Пауза між відео
        if comments_done < COMMENTS_TOTAL:
            print(f"  ⏱️ Пауза перед наступним відео...")
            wait_human_like(DELAY_BETWEEN_VIDEOS[0], DELAY_BETWEEN_VIDEOS[1])
        
        # Кожні 3 коментарі прокручуємо сторінку
        if comments_done % 3 == 0 and comments_done > 0:
            scroll_slowly(driver, 500)
            
    except Exception as e:
        print(f"  ❌ ПОМИЛКА: {str(e)[:80]}")
        try:
            driver.back()
        except:
            pass
        wait_human_like(3, 5)
        video_index += 1

# ========== ПІДСУМКИ ==========
print("\n" + "=" * 70)
print("📊 ПІДСУМКИ")
print("=" * 70)
print(f"✅ ЗРОБЛЕНО КОМЕНТАРІВ: {comments_done}")
print(f"📹 ПЕРЕГЛЯНУТО ВІДЕО: {comments_done + skipped_videos}")
print(f"⏭️ ПРОПУЩЕНО ВІДЕО: {skipped_videos}")
print(f"❌ НЕ ВДАЛОСЯ: {COMMENTS_TOTAL - comments_done}")
print("=" * 70)

