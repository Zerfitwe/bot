# ========== ЗБИРАЄМО ВСІ ВІДЕО ==========
print("\n📹 Збираємо відео...")

# Прокручуємо сторінку вниз, щоб завантажити більше відео
for scroll in range(2):
    driver.execute_script("window.scrollBy(0, 800);")
    time.sleep(2)

videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
print(f"Знайдено відео: {len(videos)}")

if len(videos) == 0:
    print("❌ Відео не знайдено!")
    driver.quit()
    exit()

# ========== КОМЕНТУЄМО ВІДЕО ПО ЧЕРЗІ ==========
print(f"\n🚀 Починаємо коментувати {min(COMMENTS_PER_SESSION, len(videos))} відео...\n")
print("=" * 70)

comments_done = 0
video_index = 0
total_to_comment = min(COMMENTS_PER_SESSION, len(videos))

while comments_done < total_to_comment:
    try:
        # Оновлюємо список відео (якщо треба)
        if video_index >= len(videos):
            # Прокручуємо щоб завантажити ще
            driver.execute_script("window.scrollBy(0, 800);")
            time.sleep(2)
            videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
            if video_index >= len(videos):
                print("⚠️ Відео закінчилися!")
                break
        
        print(f"\n{'='*60}")
        print(f"📹 ВІДЕО #{comments_done + 1} з {total_to_comment}")
        print(f"{'='*60}")
        
        # Прокручуємо до відео
        driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", videos[video_index])
        time.sleep(1)
        
        # Зберігаємо URL відео для прямого переходу
        video_url = videos[video_index].get_attribute("href")
        print(f"  🔗 URL: {video_url[:60]}...")
        
        # Відкриваємо відео через пряме посилання (найнадійніше)
        print(f"  🖱️ Відкриваємо відео...")
        driver.get(video_url)
        time.sleep(5)
        
        # Перевіряємо чи відео відкрилося
        if "video" in driver.current_url:
            print(f"  ✅ Відео відкрито!")
            
            # Генеруємо коментар
            comment_text = generate_comment()
            
            # Коментуємо
            success = comment_on_current_video(driver, comments_done + 1, comment_text)
            
            if success:
                comments_done += 1
                
                # Пауза після коментаря
                delay = random.uniform(DELAY_BETWEEN_COMMENTS[0], DELAY_BETWEEN_COMMENTS[1])
                print(f"  ⏱️ Пауза {delay:.1f} сек...")
                time.sleep(delay)
            else:
                print(f"  ⚠️ Не вдалося закоментувати це відео")
            
            # Закриваємо відео (повертаємось до стрічки)
            print(f"  🔙 Повертаємось до стрічки...")
            driver.back()
            time.sleep(3)
            
            # Оновлюємо список відео після повернення
            videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
            
        else:
            print(f"  ❌ Не вдалося відкрити відео")
            driver.back()
            time.sleep(3)
        
        video_index += 1
        
        # Кожні 3 відео прокручуємо сторінку
        if video_index % 3 == 0:
            driver.execute_script("window.scrollBy(0, 500);")
            time.sleep(2)
            print(f"  📜 Прокручуємо сторінку...")
        
    except Exception as e:
        print(f"  ❌ ПОМИЛКА: {str(e)[:80]}")
        try:
            driver.back()
        except:
            driver.get("https://www.tiktok.com")
        time.sleep(3)
        video_index += 1

