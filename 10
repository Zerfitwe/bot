SEARCH_QUERY = "Децкоє питання"
COMMENTS_PER_SESSION = 10  # Скільки відео прокоментувати
DELAY_BETWEEN_COMMENTS = (5, 8)  # Пауза між відео

# Слова для коментарів
short_words = [
    "круто", "супер", "топ", "класс", "вау", "мега", "красота",
    "имба", "кайф", "шедевр", "прекрасно", "огонь", "сила", 
    "топчик", "крутяк", "зачет", "ништяк", "смешно", "прикольно",
    "реально", "точно", "🔥", "💯", "😍", "пушка"
]

long_words = [
    "невероятно", "фантастически", "потрясающе", "захватывающе",
    "восхитительно", "бесподобно", "безупречно", "великолепно",
    "лучший", "гениально", "профессионально", "талантливо",
    "мастерски", "креативно", "оригинально", "уникально"
]

def generate_comment():
    """Генерує випадковий коментар"""
    base = "@Lisscre "
    if random.choice([True, False]):
        num = random.randint(1, 3)
        words = random.sample(short_words, num)
    else:
        num = random.randint(2, 4)
        words = random.sample(long_words, num)
    return base + " ".join(words)

def comment_on_current_video(driver, video_number, comment_text):
    """Коментує поточне відкрите відео"""
    try:
        print(f"  💬 Шукаємо поле коментаря...")
        
        # Шукаємо поле коментаря
        comment_input = None
        
        # Спосіб 1: через клас public-DraftEditor-content
        try:
            comment_input = WebDriverWait(driver, 5).until(
                EC.presence_of_element_located((By.CSS_SELECTOR, "div.public-DraftEditor-content"))
            )
            print(f"  ✅ Знайдено поле коментаря!")
        except:
            pass
        
        # Спосіб 2: через data-e2e
        if not comment_input:
            try:
                comment_input = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-input']")
                print(f"  ✅ Знайдено через data-e2e")
            except:
                pass
        
        # Спосіб 3: через textarea
        if not comment_input:
            try:
                comment_input = driver.find_element(By.TAG_NAME, "textarea")
                print(f"  ✅ Знайдено через textarea")
            except:
                pass
        
        if comment_input:
            # Клікаємо на поле
            driver.execute_script("arguments[0].click();", comment_input)
            time.sleep(1)
            
            print(f"  📝 Коментар: {comment_text}")
            
            # Вводимо текст
            try:
                comment_input.send_keys(comment_text)
            except:
                driver.execute_script("arguments[0].innerText = arguments[1];", comment_input, comment_text)
            
            time.sleep(2)
            
            # Шукаємо кнопку відправки
            submit = None
            try:
                submit = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-post']")
            except:
                try:
                    submit = driver.find_element(By.XPATH, "//button[contains(text(), 'Отправить')]")
                except:
                    pass
            
            if submit:
                submit.click()
                print(f"  ✅ КОМЕНТАР ВІДПРАВЛЕНО!")
                return True
            else:
                print(f"  ⚠️ Не знайдено кнопку, пробуємо Enter...")
                try:
                    comment_input.send_keys(Keys.RETURN)
                    print(f"  ✅ Відправлено через Enter!")
                    return True
                except:
                    print(f"  ❌ Не вдалося відправити")
                    return False
        else:
            print(f"  ❌ Не знайдено поле коментаря!")
            return False
            
    except Exception as e:
        print(f"  ❌ Помилка коментування: {str(e)[:80]}")
        return False

def close_video(driver):
    """Закриває поточне відео"""
    try:
        close = driver.find_element(By.CSS_SELECTOR, "[data-e2e='close']")
        close.click()
        time.sleep(2)
        return True
    except:
        try:
            driver.back()
            time.sleep(2)
            return True
        except:
            return False

