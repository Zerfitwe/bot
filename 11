from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
import time
import random
import os

# ==================== НАЛАШТУВАННЯ ====================

SEARCH_QUERY = "Децкоє питання"
COMMENTS_PER_SESSION = 10
DELAY_BETWEEN_COMMENTS = (5, 8)

# Слова для коментарів
short_words = [
    "круто", "супер", "топ", "класс", "вау", "мега", "красота",
    "имба", "кайф", "шедевр", "прекрасно", "огонь", "сила", 
    "топчик", "крутяк", "зачет", "ништяк", "смешно", "прикольно",
    "реально", "точно", "🔥", "💯", "😍", "пушка"
]

long_words = [
    "невероятно", "фантастически", "потрясающе", "захватывающе",
    "восхитительно", "бесподобно", "безупречно", "великолепно",
    "лучший", "гениально", "профессионально", "талантливо",
    "мастерски", "креативно", "оригинально", "уникально"
]

def generate_comment():
    base = "@Lisscre "
    if random.choice([True, False]):
        num = random.randint(1, 3)
        words = random.sample(short_words, num)
    else:
        num = random.randint(2, 4)
        words = random.sample(long_words, num)
    return base + " ".join(words)

print("=" * 70)
print("🤖 TikTok КОММЕНТАТОР (ПРОСТА ВЕРСІЯ)")
print("=" * 70)

# ЗАКРИЙТЕ ВСІ ВІКНА CHROME ПЕРЕД ЗАПУСКОМ!
print("\n⚠️ ПЕРЕД ЗАПУСКОМ ЗАКРИЙТЕ ВСІ ВІКНА CHROME!")
print("   Натисніть Enter коли закриєте...")
input()

# Простий запуск без збереження сесії
options = webdriver.ChromeOptions()
options.add_argument("--disable-blink-features=AutomationControlled")
options.add_experimental_option("excludeSwitches", ["enable-automation"])

driver = webdriver.Chrome(options=options)
driver.get("https://www.tiktok.com")
time.sleep(5)

print("\n⚠️ Увійдіть в TikTok і натисніть Enter...")
input()

# Пошук відео
print(f"\n🔍 Шукаємо: {SEARCH_QUERY}")
try:
    search = driver.find_element(By.NAME, "q")
    search.clear()
    search.send_keys(SEARCH_QUERY)
    search.send_keys(Keys.RETURN)
    time.sleep(5)
    print("✅ Пошук виконано!")
except Exception as e:
    print(f"❌ Помилка пошуку: {e}")
    driver.quit()
    exit()

# Збираємо відео
print("\n📹 Збираємо відео...")
for scroll in range(2):
    driver.execute_script("window.scrollBy(0, 800);")
    time.sleep(2)

videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
print(f"Знайдено відео: {len(videos)}")

if len(videos) == 0:
    print("❌ Відео не знайдено!")
    driver.quit()
    exit()

# Коментуємо відео по черзі
print(f"\n🚀 Починаємо коментувати...\n")

comments_done = 0
video_index = 0

for i in range(min(COMMENTS_PER_SESSION, len(videos))):
    print(f"\n{'='*50}")
    print(f"📹 ВІДЕО #{i+1}")
    print(f"{'='*50}")
    
    try:
        # Отримуємо URL відео
        video_url = videos[video_index].get_attribute("href")
        print(f"  🔗 Відкриваємо відео...")
        
        # Відкриваємо відео
        driver.get(video_url)
        time.sleep(5)
        
        # Коментуємо
        print(f"  💬 Коментуємо...")
        
        # Шукаємо поле коментаря
        comment_input = None
        try:
            comment_input = WebDriverWait(driver, 5).until(
                EC.presence_of_element_located((By.CSS_SELECTOR, "div.public-DraftEditor-content"))
            )
        except:
            try:
                comment_input = driver.find_element(By.TAG_NAME, "textarea")
            except:
                pass
        
        if comment_input:
            comment_text = generate_comment()
            comment_input.click()
            time.sleep(1)
            comment_input.send_keys(comment_text)
            time.sleep(2)
            
            # Шукаємо кнопку відправки
            try:
                submit = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-post']")
                submit.click()
                print(f"  ✅ {comment_text}")
                comments_done += 1
            except:
                try:
                    comment_input.send_keys(Keys.RETURN)
                    print(f"  ✅ {comment_text}")
                    comments_done += 1
                except:
                    print(f"  ❌ Не вдалося відправити")
        else:
            print(f"  ❌ Не знайдено поле коментаря")
        
        # Повертаємось назад
        driver.back()
        time.sleep(3)
        
        # Оновлюємо список відео
        videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
        video_index += 1
        
        # Пауза
        delay = random.uniform(DELAY_BETWEEN_COMMENTS[0], DELAY_BETWEEN_COMMENTS[1])
        print(f"  ⏱️ Пауза {delay:.1f} сек")
        time.sleep(delay)
        
    except Exception as e:
        print(f"  ❌ Помилка: {str(e)[:80]}")
        driver.back()
        time.sleep(3)
        video_index += 1

# Підсумки
print("\n" + "=" * 70)
print(f"✅ ЗРОБЛЕНО КОМЕНТАРІВ: {comments_done}")
print("=" * 70)

print("\n🔒 Натисніть Enter для виходу...")
input()
driver.quit()
