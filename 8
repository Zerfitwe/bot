from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
import time
import random
import os

# ==================== НАЛАШТУВАННЯ ====================

SEARCH_QUERY = "Децкоє питання"
COMMENTS_PER_SESSION = 10
DELAY_BETWEEN_COMMENTS = (5, 8)

# Слова для коментарів
words = [
    "круто", "супер", "топ", "класс", "вау", "мега", "красота",
    "имба", "кайф", "шедевр", "прекрасно", "огонь", "сила", 
    "топчик", "крутяк", "зачет", "ништяк", "смешно", "прикольно",
    "реально", "точно", "🔥", "💯", "😍", "пушка", "имбово"
]

def generate_comment():
    base = "@Lisscre "
    num = random.randint(1, 3)
    chosen = random.sample(words, num)
    return base + " ".join(chosen)

print("=" * 60)
print("🤖 TikTok КОММЕНТАТОР (FINAL)")
print("=" * 60)

# Запуск браузера з сесією
user_data_dir = os.path.join(os.getcwd(), "chrome_session")
options = webdriver.ChromeOptions()
options.add_argument(f"--user-data-dir={user_data_dir}")

driver = webdriver.Chrome(options=options)
driver.get("https://www.tiktok.com")
time.sleep(5)

print("\n⚠️ Ви вже залогінені? Якщо так - натисніть Enter...")
input()

# ========== ПОШУК ВІДЕО ==========
print(f"\n🔍 Шукаємо: {SEARCH_QUERY}")

try:
    search = WebDriverWait(driver, 10).until(
        EC.presence_of_element_located((By.NAME, "q"))
    )
    search.clear()
    search.send_keys(SEARCH_QUERY)
    search.send_keys(Keys.RETURN)
    time.sleep(5)
    print("✅ Пошук виконано!")
except Exception as e:
    print(f"❌ Помилка пошуку: {e}")
    print("Спробуйте ввести запит вручну і натисніть Enter")
    input()

# ========== ЗБИРАЄМО ВІДЕО ==========
print("\n📹 Збираємо відео...")

videos = []
for attempt in range(3):
    videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
    if len(videos) > 0:
        break
    time.sleep(2)

print(f"Знайдено відео: {len(videos)}")

if len(videos) == 0:
    print("❌ Відео не знайдено!")
    driver.quit()
    exit()

# ========== КОМЕНТУВАННЯ ==========
print(f"\n🚀 Починаємо коментувати {COMMENTS_PER_SESSION} відео...\n")

comments_done = 0
video_index = 0

for i in range(COMMENTS_PER_SESSION):
    if video_index >= len(videos):
        print("⚠️ Відео закінчилися!")
        break
    
    print(f"\n[{i+1}/{COMMENTS_PER_SESSION}] Відео {video_index + 1}")
    
    try:
        # Відкриваємо відео
        driver.execute_script("arguments[0].scrollIntoView();", videos[video_index])
        time.sleep(1)
        videos[video_index].click()
        time.sleep(4)
        
        # Шукаємо поле коментаря (знайдений спосіб!)
        comment_input = None
        
        # Спосіб 1: через клас public-DraftEditor-content (ТОЙ ЩО ПРАЦЮЄ!)
        try:
            comment_input = WebDriverWait(driver, 5).until(
                EC.presence_of_element_located((By.CSS_SELECTOR, "div.public-DraftEditor-content"))
            )
            print("  ✅ Знайдено поле коментаря!")
        except:
            pass
        
        # Спосіб 2: через data-e2e
        if not comment_input:
            try:
                comment_input = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-input']")
                print("  ✅ Знайдено через data-e2e")
            except:
                pass
        
        # Спосіб 3: через textarea
        if not comment_input:
            try:
                comment_input = driver.find_element(By.TAG_NAME, "textarea")
                print("  ✅ Знайдено через textarea")
            except:
                pass
        
        if comment_input:
            # Клікаємо на поле коментаря
            driver.execute_script("arguments[0].click();", comment_input)
            time.sleep(1)
            
            # Генеруємо і вводимо коментар
            comment_text = generate_comment()
            
            # Вводимо текст (різними способами)
            try:
                comment_input.send_keys(comment_text)
            except:
                driver.execute_script("arguments[0].innerText = arguments[1];", comment_input, comment_text)
            
            print(f"  📝 Коментар: {comment_text}")
            time.sleep(2)
            
            # Шукаємо кнопку відправки
            submit = None
            
            try:
                submit = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-post']")
            except:
                try:
                    submit = driver.find_element(By.XPATH, "//button[contains(text(), 'Отправить')]")
                except:
                    pass
            
            if submit:
                submit.click()
                print(f"  ✅ ВІДПРАВЛЕНО!")
                comments_done += 1
                time.sleep(3)
            else:
                print("  ⚠️ Не знайдено кнопку відправки")
                # Спробуємо натиснути Enter
                try:
                    comment_input.send_keys(Keys.RETURN)
                    print("  ✅ Відправлено через Enter")
                    comments_done += 1
                except:
                    pass
        else:
            print("  ❌ Не знайдено поле коментаря")
        
        # Закриваємо відео
        try:
            close = driver.find_element(By.CSS_SELECTOR, "[data-e2e='close']")
            close.click()
        except:
            driver.get("https://www.tiktok.com")
            time.sleep(3)
        
        video_index += 1
        
        # Пауза між коментарями
        delay = random.uniform(DELAY_BETWEEN_COMMENTS[0], DELAY_BETWEEN_COMMENTS[1])
        print(f"  ⏱️ Пауза {delay:.1f} сек")
        time.sleep(delay)
        
        # Оновлюємо список відео кожні 3 коментарі
        if video_index % 3 == 0:
            driver.execute_script("window.scrollBy(0, 800);")
            time.sleep(2)
            videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
            print(f"  📜 Оновлено список: {len(videos)} відео")
        
    except Exception as e:
        print(f"  ❌ Помилка: {str(e)[:80]}")
        try:
            close = driver.find_element(By.CSS_SELECTOR, "[data-e2e='close']")
            close.click()
        except:
            pass
        video_index += 1
        time.sleep(2)

# ========== ПІДСУМКИ ==========
print("\n" + "=" * 60)
print(f"✅ ЗРОБЛЕНО КОМЕНТАРІВ: {comments_done}/{COMMENTS_PER_SESSION}")
print("=" * 60)

# Зберігаємо лог
with open("comments_log.txt", "a", encoding="utf-8") as f:
    f.write(f"\nСесія: {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
    f.write(f"Зроблено: {comments_done} коментарів\n")
    f.write("=" * 40 + "\n")

print("\n💾 Лог збережено у comments_log.txt")
print("\n🔒 Натисніть Enter для виходу...")
input()
driver.quit()
