# Сохраняем сессию
user_data_dir = os.path.join(os.getcwd(), "chrome_session")
options = webdriver.ChromeOptions()
options.add_argument(f"--user-data-dir={user_data_dir}")

print("\n📥 Запускаем Chrome...")
service = Service(ChromeDriverManager().install())
driver = webdriver.Chrome(service=service, options=options)

driver.get("https://www.tiktok.com")
time.sleep(3)

print("\n⚠️ ВОЙДИТЕ В АККАУНТ и нажмите Enter...")
input()

# Поиск
print(f"\n🔍 Ищем: {SEARCH_QUERY}")
try:
    search = WebDriverWait(driver, 10).until(EC.presence_of_element_located((By.NAME, "q")))
    search.send_keys(SEARCH_QUERY)
    search.send_keys(Keys.RETURN)
    time.sleep(5)
    print("✅ Найдено!")
except:
    print("❌ Ошибка поиска")
    driver.quit()
    exit()

# Комментируем
print(f"\n🚀 Делаем {COMMENTS_PER_SESSION} комментариев...\n")

video_index = 0
comments_done = 0
comments_log = []

for i in range(COMMENTS_PER_SESSION):
    comment = generate_comment()
    print(f"[{i+1}/{COMMENTS_PER_SESSION}] {comment[:40]}...")
    
    if video_index > 0 and video_index % 5 == 0:
        driver.execute_script("window.scrollBy(0, 800);")
        time.sleep(2)
    
    if comment_on_video(driver, video_index, comment):
        comments_done += 1
        video_index += 1
        comments_log.append(f"{time.strftime('%H:%M:%S')} - {comment}")
        delay = random.uniform(DELAY_BETWEEN_COMMENTS[0], DELAY_BETWEEN_COMMENTS[1])
        print(f"  ⏱️ Пауза {delay:.1f} сек")
        time.sleep(delay)
    else:
        print(f"  ⚠️ Не удалось")
        time.sleep(2)

save_log(comments_log)

print("\n" + "=" * 60)
print(f"✅ Сделано: {comments_done}/{COMMENTS_PER_SESSION}")
print("=" * 60)

print("\n🔒 Нажмите Enter для закрытия...")
input()
driver.quit()
