    "крутяк", "бомбезно", "зачет", "ништяк", "смешно", "прикольно",
    "реально", "точно", "🔥", "💯", "😍", "пушка", "имбово", "краш"
]

long_words = [
    "невероятно", "фантастически", "потрясающе", "захватывающе",
    "восхитительно", "бесподобно", "безупречно", "великолепно",
    "лучший", "гениально", "профессионально", "талантливо",
    "мастерски", "креативно", "оригинально", "уникально",
    "вдохновляюще", "мотивирующе", "энергично", "динамично",
    "эмоционально", "искренне", "душевно", "гармонично",
    "стильно", "современно", "инновационно", "качественно",
    "эффективно", "успешно", "масштабно", "уверенно"
