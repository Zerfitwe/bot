# ==================== НАЛАШТУВАННЯ ====================

SEARCH_QUERY = "Децкоє питання"  # Можете змінити тему
COMMENTS_PER_ACCOUNT = 10  # Скільки коментарів з одного акаунта
VIDEOS_TO_COMMENT = 15  # Всього відео прокоментувати
DELAY_BETWEEN_COMMENTS = (1, 3)  # Пауза між коментарями (секунди)

