from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
import time
import random
import os

# ==================== НАЛАШТУВАННЯ ====================

SEARCH_QUERY = "Децкоє питання"
COMMENTS_PER_SESSION = 10

# Слова для коментарів
words = [
    "круто", "супер", "топ", "класс", "вау", "мега", "красота",
    "имба", "кайф", "шедевр", "прекрасно", "огонь", "сила", 
    "топчик", "крутяк", "зачет", "ништяк", "смешно", "прикольно",
    "реально", "точно", "🔥", "💯", "😍", "пушка"
]

def generate_comment():
    base = "@Lisscre "
    num = random.randint(1, 3)
    chosen = random.sample(words, num)
    return base + " ".join(chosen)

print("=" * 60)
print("🤖 TikTok Бот")
print("=" * 60)

# Запуск браузера з сесією
user_data_dir = os.path.join(os.getcwd(), "chrome_session")
options = webdriver.ChromeOptions()
options.add_argument(f"--user-data-dir={user_data_dir}")

driver = webdriver.Chrome(options=options)
driver.get("https://www.tiktok.com")
time.sleep(5)

print("\n⚠️ Увійдіть в TikTok і натисніть Enter...")
input()

# ========== ПОШУК ВІДЕО ==========
print("\n🔍 Пошук відео...")

try:
    # Шукаємо поле пошуку
    search = driver.find_element(By.NAME, "q")
    search.clear()
    search.send_keys(SEARCH_QUERY)
    search.send_keys(Keys.RETURN)
    time.sleep(5)
    print("✅ Пошук виконано!")
except Exception as e:
    print(f"❌ Не знайдено поле пошуку: {e}")
    print("Спробуйте знайти поле пошуку вручну і ввести запит")
    input("Після введення запиту натисніть Enter...")

# ========== ЗБИРАЄМО ВІДЕО ==========
print("\n📹 Збираємо відео...")

videos = []
for attempt in range(3):
    videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
    if len(videos) > 0:
        break
    time.sleep(2)

print(f"Знайдено відео: {len(videos)}")

if len(videos) == 0:
    print("❌ Відео не знайдено!")
    driver.quit()
    exit()

# ========== КОМЕНТУВАННЯ ==========
print(f"\n🚀 Починаємо коментувати {COMMENTS_PER_SESSION} відео...\n")

comments_done = 0
video_index = 0

for i in range(COMMENTS_PER_SESSION):
    if video_index >= len(videos):
        print("⚠️ Відео закінчилися!")
        break
    
    print(f"\n[{i+1}/{COMMENTS_PER_SESSION}] Відео {video_index + 1}")
    
    try:
        # Відкриваємо відео
        driver.execute_script("arguments[0].scrollIntoView();", videos[video_index])
        time.sleep(1)
        videos[video_index].click()
        time.sleep(4)
        
        # Шукаємо поле коментаря (спробуємо різні варіанти)
        comment_input = None
        
        # Варіант 1
        try:
            comment_input = WebDriverWait(driver, 5).until(
                EC.presence_of_element_located((By.CSS_SELECTOR, "[data-e2e='comment-input']"))
            )
            print("  ✅ Знайдено поле через data-e2e")
        except:
            pass
        
        # Варіант 2
        if not comment_input:
            try:
                comment_input = driver.find_element(By.TAG_NAME, "textarea")
                print("  ✅ Знайдено поле через textarea")
            except:
                pass
        
        # Варіант 3
        if not comment_input:
            try:
                comment_input = driver.find_element(By.CSS_SELECTOR, "div[contenteditable='true']")
                print("  ✅ Знайдено поле через contenteditable")
            except:
                pass
        
        if comment_input:
            # Вводимо коментар
            comment_input.click()
            time.sleep(1)
            comment_text = generate_comment()
            comment_input.send_keys(comment_text)
            time.sleep(2)
            
            # Шукаємо кнопку відправки
            submit = None
            
            try:
                submit = driver.find_element(By.CSS_SELECTOR, "[data-e2e='comment-post']")
            except:
                try:
                    submit = driver.find_element(By.XPATH, "//button[contains(text(), 'Отправить')]")
                except:
                    pass
            
            if submit:
                submit.click()
                print(f"  ✅ Коментар відправлено: {comment_text}")
                comments_done += 1
                time.sleep(3)
            else:
                print("  ⚠️ Не знайдено кнопку відправки")
        else:
            print("  ❌ Не знайдено поле коментаря")
        
        # Закриваємо відео
        try:
            close = driver.find_element(By.CSS_SELECTOR, "[data-e2e='close']")
            close.click()
        except:
            driver.get("https://www.tiktok.com")
            time.sleep(3)
        
        video_index += 1
        
        # Пауза
        delay = random.uniform(3, 6)
        print(f"  ⏱️ Пауза {delay:.1f} сек")
        time.sleep(delay)
        
        # Оновлюємо список відео кожні 3 коментарі
        if video_index % 3 == 0:
            driver.execute_script("window.scrollBy(0, 800);")
            time.sleep(2)
            videos = driver.find_elements(By.CSS_SELECTOR, "a[href*='/video/']")
            print(f"  📜 Оновлено список: {len(videos)} відео")
        
    except Exception as e:
        print(f"  ❌ Помилка: {str(e)[:80]}")
        try:
            close = driver.find_element(By.CSS_SELECTOR, "[data-e2e='close']")
            close.click()
        except:
            pass
        video_index += 1
        time.sleep(2)

# ========== ПІДСУМКИ ==========
print("\n" + "=" * 60)
print(f"✅ Зроблено коментарів: {comments_done}/{COMMENTS_PER_SESSION}")
print("=" * 60)

print("\n🔒 Натисніть Enter для виходу...")
input()
driver.quit()
